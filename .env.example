# Database
DATABASE_URL=postgresql://wahu:wahu_collections_2026@localhost:5432/collections
SQLALCHEMY_ECHO=true

# Redis (for APScheduler)
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Zoho API
ZOHO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
ZOHO_ORGANIZATION_ID=YOUR_ORG_ID_HERE
ZOHO_BILLING_API_URL=https://www.zohoapis.com/billing/v2

# Google Drive (for syncing Zoho invoice CSVs)
ZOHO_INVOICES_DRIVE_FOLDER_ID=19fd10Y4AZ8evazSh6SKFTurRam-vPYM1
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
DRIVE_INVOICE_FILENAME_FILTER=Invoice

# Hubtel SMS (Telecel/MTN aggregator)
HUBTEL_API_KEY=YOUR_API_KEY_HERE
HUBTEL_CLIENT_ID=YOUR_CLIENT_ID_HERE

# QuickBooks
QUICKBOOKS_REALM_ID=YOUR_REALM_ID_HERE
QUICKBOOKS_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE

# Storage (filesystem for dev, s3 for prod)
STORAGE_BACKEND=filesystem
STORAGE_PATH=./collections_data
# S3_BUCKET=wahu-collections
# AWS_REGION=us-east-1

# FastAPI
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-prod

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
